# Environment Variables for Voice-to-Website App

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Firebase Configuration (used for Phone OTP auth + JWT verification)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id

# Set to "true" to bypass reCAPTCHA and use Firebase Console test phone numbers
NEXT_PUBLIC_FIREBASE_USE_TEST_NUMBERS=true

# OpenAI API Key (required for image embedding lookup)
OPENAI_API_KEY=your_openai_api_key

# Razorpay (required for payment verification — NEVER expose key_secret client-side)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Sarvam AI (Indian language speech-to-text)
SARVAM_API_KEY=your_sarvam_api_key